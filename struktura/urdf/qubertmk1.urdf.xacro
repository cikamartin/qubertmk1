<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="qubertmk1">

  <!-- ==================== PROPERTIES ==================== -->

  <!-- ALP0020 profile: 20×20mm cross-section -->
  <xacro:property name="profile_size" value="0.020"/>

  <!-- Outer cube: 350×350×350mm -->
  <xacro:property name="cube_outer" value="0.350"/>
  <!-- Bar lengths -->
  <xacro:property name="bar_long" value="0.350"/>          <!-- X: longitudinal ALP0020-350 -->
  <xacro:property name="bar_trans" value="0.310"/>         <!-- Y: transverse ALP0020-310 (350-2×20) -->
  <xacro:property name="bar_vert" value="0.310"/>          <!-- Z: vertical ALP0020-310 (350-2×20) -->
  <!-- Center-to-center distances between parallel bars -->
  <xacro:property name="frame_y_cc" value="${cube_outer - profile_size}"/>  <!-- 330mm Y -->
  <xacro:property name="frame_z_cc" value="${cube_outer - profile_size}"/>  <!-- 330mm Z -->

  <!-- Transverse bars: 275mm apart, centered on 350mm longitudinal -->
  <xacro:property name="crossbar_spacing" value="0.275"/>
  <xacro:property name="crossbar_offset"  value="${crossbar_spacing / 2}"/>  <!-- ±137.5mm from center -->

  <!-- Nissan Leaf e-NV200 battery module -->
  <xacro:property name="battery_length" value="0.315"/>
  <xacro:property name="battery_width"  value="0.222"/>
  <xacro:property name="battery_height" value="0.035"/>
  <xacro:property name="battery_mass"   value="3.8"/>

  <!-- DDSM115 hub motor wheel -->
  <xacro:property name="wheel_radius" value="0.0575"/>    <!-- ~115mm diameter -->
  <xacro:property name="wheel_width"  value="0.048"/>
  <xacro:property name="wheel_mass"   value="0.52"/>

  <!-- Suspension travel -->
  <xacro:property name="suspension_travel" value="0.030"/>

  <!-- Wheel positions (from chassis center, at bottom frame corners) -->
  <xacro:property name="wheel_x" value="${crossbar_offset}"/>
  <xacro:property name="wheel_y" value="${cube_outer / 2 + 0.030}"/>  <!-- frame edge + 10mm half-profile + 20mm suspension gap -->
  <xacro:property name="wheel_z" value="${-cube_outer / 2}"/>

  <!-- RoArm-M2-S dimensions (approximate) -->
  <xacro:property name="arm_base_size" value="0.060"/>
  <xacro:property name="arm_link_length" value="0.098"/>
  <xacro:property name="arm_mass" value="0.53"/>

  <!-- Head -->
  <xacro:property name="head_width"  value="0.180"/>
  <xacro:property name="head_depth"  value="0.150"/>
  <xacro:property name="head_height" value="0.130"/>
  <xacro:property name="head_mass"   value="0.5"/>

  <!-- ==================== MATERIALS ==================== -->

  <material name="aluminium">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="battery_blue">
    <color rgba="0.15 0.25 0.55 1.0"/>
  </material>
  <material name="petg_orange">
    <color rgba="0.95 0.55 0.1 1.0"/>
  </material>
  <material name="black_rubber">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>

  <!-- ==================== MACROS ==================== -->

  <!-- Inertia helpers -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+l*l)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- Mesh base path -->
  <xacro:property name="mesh_dir" value="package://qubertmk1_description/meshes"/>

  <!-- Profile bar macro: mesh is along Z in STL, centered at (128,128,L/2) mm -->
  <!-- We rotate Z→X (rpy 0 pi/2 0) and shift to center at link origin -->
  <xacro:macro name="profile_bar" params="name length mesh_file parent *origin">
    <link name="${name}">
      <visual>
        <origin xyz="${-length/2} -0.128 0.128" rpy="0 ${pi/2} 0"/>
        <geometry>
          <mesh filename="${mesh_dir}/chassis/${mesh_file}" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="aluminium"/>
      </visual>
      <collision>
        <geometry>
          <box size="${length} ${profile_size} ${profile_size}"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="${0.55 * length}" x="${length}" y="${profile_size}" z="${profile_size}"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <xacro:insert_block name="origin"/>
    </joint>
  </xacro:macro>

  <!-- Printed corner piece macro (simplified as small box at joint) -->
  <xacro:macro name="corner_piece" params="name parent *origin">
    <link name="${name}">
      <visual>
        <geometry>
          <box size="0.040 0.040 0.040"/>
        </geometry>
        <material name="petg_orange"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.040 0.040 0.040"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="0.05" x="0.040" y="0.040" z="0.040"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <xacro:insert_block name="origin"/>
    </joint>
  </xacro:macro>

  <!-- Wheel + suspension macro (ugv.stl includes wheel + suspension as one piece) -->
  <!-- ugv.stl bounds: (88.3,77.7,0)→(167.7,178.3,100.7) mm, center ~(128,128,50) mm -->
  <!-- URDF visual: first rotates mesh by rpy, THEN translates by xyz -->
  <!-- So xyz must be: -R_z(angle) * mesh_center to re-center after rotation -->
  <!-- Left (y_sign=+1): R_z(+pi/2) → center goes to (-0.128, 0.128) → xyz=(0.128, -0.128) -->
  <!-- Right(y_sign=-1): R_z(-pi/2) → center goes to (0.128, -0.128) → xyz=(-0.128, 0.128) -->
  <xacro:macro name="wheel_assembly" params="prefix x_sign y_sign">
    <link name="${prefix}_suspension">
      <visual>
        <origin xyz="${y_sign * 0.128} ${-y_sign * 0.128} -0.050" rpy="0 0 ${y_sign * pi/2}"/>
        <geometry>
          <mesh filename="${mesh_dir}/chassis/ugv.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.080 0.100 0.100"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="${wheel_mass + 0.3}" x="0.080" y="0.100" z="0.100"/>
    </link>
    <joint name="${prefix}_suspension_joint" type="prismatic">
      <parent link="base_link"/>
      <child link="${prefix}_suspension"/>
      <origin xyz="${x_sign * wheel_x} ${y_sign * wheel_y} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-suspension_travel}" upper="${suspension_travel}" effort="500" velocity="0.5"/>
      <dynamics damping="50.0" friction="5.0"/>
    </joint>
  </xacro:macro>

  <!-- RoArm-M2-S 4-DOF arm macro -->
  <xacro:macro name="roarm_m2s" params="prefix parent *origin has_gripper">
    <!-- Arm base / turntable (joint 1: rotation around Z) -->
    <link name="${prefix}_base">
      <visual>
        <geometry>
          <cylinder radius="0.035" length="0.030"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.035" length="0.030"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.1" r="0.035" l="0.030"/>
    </link>
    <joint name="${prefix}_base_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${prefix}_base"/>
      <xacro:insert_block name="origin"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi}" upper="${pi}" effort="5" velocity="3.14"/>
    </joint>

    <!-- Shoulder (joint 2: pitch around Y) -->
    <link name="${prefix}_shoulder">
      <visual>
        <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.030 ${arm_link_length}"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="0.030 0.030 ${arm_link_length}"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="0.12" x="0.030" y="0.030" z="${arm_link_length}"/>
    </link>
    <joint name="${prefix}_shoulder_joint" type="revolute">
      <parent link="${prefix}_base"/>
      <child link="${prefix}_shoulder"/>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-pi/2}" upper="${pi/2}" effort="5" velocity="3.14"/>
    </joint>

    <!-- Elbow (joint 3: pitch around Y) -->
    <link name="${prefix}_elbow">
      <visual>
        <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.025 ${arm_link_length}"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.025 ${arm_link_length}"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="0.10" x="0.025" y="0.025" z="${arm_link_length}"/>
    </link>
    <joint name="${prefix}_elbow_joint" type="revolute">
      <parent link="${prefix}_shoulder"/>
      <child link="${prefix}_elbow"/>
      <origin xyz="0 0 ${arm_link_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-2.35}" upper="${2.35}" effort="5" velocity="3.14"/>
    </joint>

    <!-- Wrist (joint 4: roll around Z) -->
    <link name="${prefix}_wrist">
      <visual>
        <geometry>
          <cylinder radius="0.015" length="0.025"/>
        </geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.015" length="0.025"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="0.05" r="0.015" l="0.025"/>
    </link>
    <joint name="${prefix}_wrist_joint" type="revolute">
      <parent link="${prefix}_elbow"/>
      <child link="${prefix}_wrist"/>
      <origin xyz="0 0 ${arm_link_length}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-pi}" upper="${pi}" effort="3" velocity="3.14"/>
    </joint>

    <!-- Gripper (only for arms 1 and 2) -->
    <xacro:if value="${has_gripper}">
      <link name="${prefix}_gripper_left">
        <visual>
          <origin xyz="0.015 0 0.020" rpy="0 0 0"/>
          <geometry>
            <box size="0.008 0.020 0.040"/>
          </geometry>
          <material name="dark_grey"/>
        </visual>
        <collision>
          <origin xyz="0.015 0 0.020" rpy="0 0 0"/>
          <geometry>
            <box size="0.008 0.020 0.040"/>
          </geometry>
        </collision>
        <xacro:box_inertia m="0.02" x="0.008" y="0.020" z="0.040"/>
      </link>
      <joint name="${prefix}_gripper_left_joint" type="prismatic">
        <parent link="${prefix}_wrist"/>
        <child link="${prefix}_gripper_left"/>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="0" upper="0.025" effort="2" velocity="0.1"/>
      </joint>

      <link name="${prefix}_gripper_right">
        <visual>
          <origin xyz="-0.015 0 0.020" rpy="0 0 0"/>
          <geometry>
            <box size="0.008 0.020 0.040"/>
          </geometry>
          <material name="dark_grey"/>
        </visual>
        <collision>
          <origin xyz="-0.015 0 0.020" rpy="0 0 0"/>
          <geometry>
            <box size="0.008 0.020 0.040"/>
          </geometry>
        </collision>
        <xacro:box_inertia m="0.02" x="0.008" y="0.020" z="0.040"/>
      </link>
      <joint name="${prefix}_gripper_right_joint" type="prismatic">
        <parent link="${prefix}_wrist"/>
        <child link="${prefix}_gripper_right"/>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-0.025" upper="0" effort="2" velocity="0.1"/>
      </joint>
    </xacro:if>
  </xacro:macro>

  <!-- ==================== BASE LINK ==================== -->
  <!-- base_link at geometric center of cube chassis -->

  <link name="base_footprint"/>

  <link name="base_link">
    <!-- No visual — the frame is built from individual profile bars -->
    <collision>
      <geometry>
        <box size="${cube_outer} ${cube_outer} ${cube_outer}"/>
      </geometry>
    </collision>
    <!-- Rough total chassis mass including frame, corners, fasteners -->
    <xacro:box_inertia m="2.5" x="${cube_outer}" y="${cube_outer}" z="${cube_outer}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${cube_outer/2 + wheel_radius + 0.04}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CHASSIS FRAME PROFILES ==================== -->
  <!-- Bottom frame: 2× longitudinal (350mm, along X) -->
  <xacro:profile_bar name="bottom_long_left" length="${bar_long}" mesh_file="alp0020350.stl" parent="base_link">
    <origin xyz="0 ${frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="bottom_long_right" length="${bar_long}" mesh_file="alp0020350.stl" parent="base_link">
    <origin xyz="0 ${-frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:profile_bar>

  <!-- Bottom frame: 2× transverse (310mm, along Y, 275mm apart) -->
  <xacro:profile_bar name="bottom_cross_front" length="${bar_trans}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${crossbar_offset} 0 ${-frame_z_cc/2}" rpy="0 0 ${pi/2}"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="bottom_cross_rear" length="${bar_trans}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${-crossbar_offset} 0 ${-frame_z_cc/2}" rpy="0 0 ${pi/2}"/>
  </xacro:profile_bar>

  <!-- Top frame: same as bottom -->
  <xacro:profile_bar name="top_long_left" length="${bar_long}" mesh_file="alp0020350.stl" parent="base_link">
    <origin xyz="0 ${frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="top_long_right" length="${bar_long}" mesh_file="alp0020350.stl" parent="base_link">
    <origin xyz="0 ${-frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="top_cross_front" length="${bar_trans}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${crossbar_offset} 0 ${frame_z_cc/2}" rpy="0 0 ${pi/2}"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="top_cross_rear" length="${bar_trans}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${-crossbar_offset} 0 ${frame_z_cc/2}" rpy="0 0 ${pi/2}"/>
  </xacro:profile_bar>

  <!-- 4× Vertical uprights (310mm, along Z) -->
  <xacro:profile_bar name="vert_front_left" length="${bar_vert}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${crossbar_offset} ${frame_y_cc/2} 0" rpy="0 ${pi/2} 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="vert_front_right" length="${bar_vert}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${crossbar_offset} ${-frame_y_cc/2} 0" rpy="0 ${pi/2} 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="vert_rear_left" length="${bar_vert}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${-crossbar_offset} ${frame_y_cc/2} 0" rpy="0 ${pi/2} 0"/>
  </xacro:profile_bar>
  <xacro:profile_bar name="vert_rear_right" length="${bar_vert}" mesh_file="ALP0020310.stl" parent="base_link">
    <origin xyz="${-crossbar_offset} ${-frame_y_cc/2} 0" rpy="0 ${pi/2} 0"/>
  </xacro:profile_bar>

  <!-- Corner pieces (8 corners of the cube) -->
  <xacro:corner_piece name="corner_btm_fl" parent="base_link">
    <origin xyz="${crossbar_offset} ${frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_btm_fr" parent="base_link">
    <origin xyz="${crossbar_offset} ${-frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_btm_rl" parent="base_link">
    <origin xyz="${-crossbar_offset} ${frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_btm_rr" parent="base_link">
    <origin xyz="${-crossbar_offset} ${-frame_y_cc/2} ${-frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_top_fl" parent="base_link">
    <origin xyz="${crossbar_offset} ${frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_top_fr" parent="base_link">
    <origin xyz="${crossbar_offset} ${-frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_top_rl" parent="base_link">
    <origin xyz="${-crossbar_offset} ${frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>
  <xacro:corner_piece name="corner_top_rr" parent="base_link">
    <origin xyz="${-crossbar_offset} ${-frame_y_cc/2} ${frame_z_cc/2}" rpy="0 0 0"/>
  </xacro:corner_piece>

  <!-- ==================== BATTERY MODULES ==================== -->

  <link name="battery_carrier">
    <visual>
      <geometry>
        <box size="${battery_length + 0.010} ${battery_width + 0.010} 0.008"/>
      </geometry>
      <material name="petg_orange"/>
    </visual>
    <collision>
      <geometry>
        <box size="${battery_length + 0.010} ${battery_width + 0.010} 0.008"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.3" x="${battery_length}" y="${battery_width}" z="0.008"/>
  </link>
  <joint name="battery_carrier_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_carrier"/>
    <origin xyz="0 0 ${-cube_outer/2 + 0.030}" rpy="0 0 0"/>
  </joint>

  <!-- Battery module 1 (bottom) -->
  <link name="battery_module_1">
    <visual>
      <geometry>
        <box size="${battery_length} ${battery_width} ${battery_height}"/>
      </geometry>
      <material name="battery_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${battery_length} ${battery_width} ${battery_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${battery_mass}" x="${battery_length}" y="${battery_width}" z="${battery_height}"/>
  </link>
  <joint name="battery_1_joint" type="fixed">
    <parent link="battery_carrier"/>
    <child link="battery_module_1"/>
    <origin xyz="0 0 ${battery_height/2 + 0.005}" rpy="0 0 0"/>
  </joint>

  <!-- Battery module 2 (on top of module 1, in series = 14.8V) -->
  <link name="battery_module_2">
    <visual>
      <geometry>
        <box size="${battery_length} ${battery_width} ${battery_height}"/>
      </geometry>
      <material name="battery_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${battery_length} ${battery_width} ${battery_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${battery_mass}" x="${battery_length}" y="${battery_width}" z="${battery_height}"/>
  </link>
  <joint name="battery_2_joint" type="fixed">
    <parent link="battery_carrier"/>
    <child link="battery_module_2"/>
    <origin xyz="0 0 ${battery_height + battery_height/2 + 0.010}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEELS + SUSPENSION ==================== -->

  <xacro:wheel_assembly prefix="front_left"  x_sign="1"  y_sign="1"/>
  <xacro:wheel_assembly prefix="front_right" x_sign="1"  y_sign="-1"/>
  <xacro:wheel_assembly prefix="rear_left"   x_sign="-1" y_sign="1"/>
  <xacro:wheel_assembly prefix="rear_right"  x_sign="-1" y_sign="-1"/>

  <!-- ==================== ARMS ==================== -->
  <!-- Arm 1: front-left top, with gripper -->
  <xacro:roarm_m2s prefix="arm_1" parent="base_link" has_gripper="true">
    <origin xyz="${cube_outer/2 - 0.04} ${cube_outer/2 - 0.04} ${cube_outer/2 + 0.01}" rpy="0 0 ${pi/4}"/>
  </xacro:roarm_m2s>

  <!-- Arm 2: front-right top, with gripper -->
  <xacro:roarm_m2s prefix="arm_2" parent="base_link" has_gripper="true">
    <origin xyz="${cube_outer/2 - 0.04} ${-cube_outer/2 + 0.04} ${cube_outer/2 + 0.01}" rpy="0 0 ${-pi/4}"/>
  </xacro:roarm_m2s>

  <!-- Arm 3: rear-center top, chaos arm, NO gripper -->
  <xacro:roarm_m2s prefix="arm_3" parent="base_link" has_gripper="false">
    <origin xyz="${-cube_outer/2 + 0.04} 0 ${cube_outer/2 + 0.01}" rpy="0 0 ${pi}"/>
  </xacro:roarm_m2s>

  <!-- ==================== HEAD ==================== -->

  <!-- Head retract mechanism (prismatic, head pops up/down from top) -->
  <link name="head_retract_slider">
    <visual>
      <geometry>
        <box size="0.040 0.040 0.060"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.040 0.040 0.060"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.1" x="0.040" y="0.040" z="0.060"/>
  </link>
  <joint name="head_retract_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="head_retract_slider"/>
    <origin xyz="0 0 ${cube_outer/2 + 0.03}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.10" effort="20" velocity="0.1"/>
  </joint>

  <!-- Neck pan (yaw around Z) -->
  <link name="neck_pan">
    <visual>
      <geometry>
        <cylinder radius="0.020" length="0.030"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.020" length="0.030"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.08" r="0.020" l="0.030"/>
  </link>
  <joint name="neck_pan_joint" type="revolute">
    <parent link="head_retract_slider"/>
    <child link="neck_pan"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="19.5" velocity="3.14"/>
  </joint>

  <!-- Neck tilt (pitch around Y) -->
  <link name="neck_tilt">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="0.025"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.025"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.06" r="0.015" l="0.025"/>
  </link>
  <joint name="neck_tilt_joint" type="revolute">
    <parent link="neck_pan"/>
    <child link="neck_tilt"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/4}" upper="${pi/3}" effort="19.5" velocity="3.14"/>
  </joint>

  <!-- Head shell (Johnny 5 style) -->
  <link name="head">
    <visual>
      <geometry>
        <box size="${head_depth} ${head_width} ${head_height}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="${head_depth} ${head_width} ${head_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${head_mass}" x="${head_depth}" y="${head_width}" z="${head_height}"/>
  </link>
  <joint name="head_joint" type="fixed">
    <parent link="neck_tilt"/>
    <child link="head"/>
    <origin xyz="0 0 ${head_height/2 + 0.015}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== SENSORS ==================== -->

  <!-- STL27L 360° LiDAR on head top -->
  <link name="lidar">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.030"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.030"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.035" l="0.030"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="head"/>
    <child link="lidar"/>
    <origin xyz="0 0 ${head_height/2 + 0.020}" rpy="0 0 0"/>
  </joint>

  <!-- Stereo camera (OS02G10, 62mm baseline, robot eyes) -->
  <link name="stereo_camera">
    <visual>
      <geometry>
        <box size="0.025 0.070 0.025"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.025 0.070 0.025"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.03" x="0.025" y="0.070" z="0.025"/>
  </link>
  <joint name="stereo_camera_joint" type="fixed">
    <parent link="head"/>
    <child link="stereo_camera"/>
    <origin xyz="${head_depth/2 + 0.005} 0 0.010" rpy="0 0 0"/>
  </joint>

  <!-- Camera optical frames -->
  <link name="camera_left_optical"/>
  <joint name="camera_left_optical_joint" type="fixed">
    <parent link="stereo_camera"/>
    <child link="camera_left_optical"/>
    <origin xyz="0 0.031 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="camera_right_optical"/>
  <joint name="camera_right_optical_joint" type="fixed">
    <parent link="stereo_camera"/>
    <child link="camera_right_optical"/>
    <origin xyz="0 -0.031 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- Eye displays (DualEye 0.71" round LCD) -->
  <link name="eye_left_display">
    <visual>
      <geometry>
        <cylinder radius="0.009" length="0.003"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="eye_left_joint" type="fixed">
    <parent link="head"/>
    <child link="eye_left_display"/>
    <origin xyz="${head_depth/2 + 0.002} 0.025 0.020" rpy="0 ${pi/2} 0"/>
  </joint>

  <link name="eye_right_display">
    <visual>
      <geometry>
        <cylinder radius="0.009" length="0.003"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="eye_right_joint" type="fixed">
    <parent link="head"/>
    <child link="eye_right_display"/>
    <origin xyz="${head_depth/2 + 0.002} -0.025 0.020" rpy="0 ${pi/2} 0"/>
  </joint>

  <!-- IMU frame (on Jetson, inside chassis) -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
